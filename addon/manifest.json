{
  "manifest_version": 2,
  "name": "Library Search",
  "version": "0.1.0",
  "description": "Search library catalogs and repositories directly from Zotero",
  "homepage_url": "https://github.com/CrispStrobe/CrispZotLib",
  "author": "Your Name",
  "icons": {
    "48": "content/icons/favicon@0.5x.png",
    "96": "content/icons/favicon.png"
  },
  "applications": {
    "zotero": {
      "id": "librarysearch@example.com",
      "update_url": "https://github.com/CrispStrobe/CrispZotLib/releases/download/release/update.json",
      "strict_min_version": "6.0",
      "strict_max_version": "7.*"
    }
  }
}